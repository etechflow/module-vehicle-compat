<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!--
        v1.1.0: register the SEO-URL router. Runs before the standard CMS
        router so /<seo_prefix>/<make>/<model>/<year>/<part> paths are
        matched as Part Finder requests rather than being interpreted as
        CMS pages. Opt-in via admin config — when disabled, the router
        returns null and standard routing continues unchanged.
    -->
    <type name="Magento\Framework\App\RouterList">
        <arguments>
            <argument name="routerList" xsi:type="array">
                <item name="etechflow_vehiclecompat_seo" xsi:type="array">
                    <item name="class" xsi:type="string">ETechFlow\VehicleCompat\Controller\Router\FitmentRouter</item>
                    <item name="disable" xsi:type="boolean">false</item>
                    <item name="sortOrder" xsi:type="string">30</item>
                </item>
            </argument>
        </arguments>
    </type>
</config>
