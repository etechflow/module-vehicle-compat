<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <etechflow_vehiclecompat>
            <license>
                <license_key></license_key>
                <production_environment>1</production_environment>
            </license>
            <general>
                <enabled>1</enabled>
                <earliest_year>1990</earliest_year>
                <show_year_field>1</show_year_field>
                <label_make>Make</label_make>
                <label_model>Model</label_model>
                <label_year>Year</label_year>
                <label_part>Parts Required</label_part>
            </general>
            <pdp_badge>
                <enabled>0</enabled>
                <prefix>Fits:</prefix>
                <style>success</style>
            </pdp_badge>
            <seo_urls>
                <enabled>0</enabled>
                <prefix>parts</prefix>
            </seo_urls>
            <garage>
                <enabled>0</enabled>
                <max_entries>3</max_entries>
            </garage>
            <copy>
                <find_button_text>Find Parts</find_button_text>
                <find_page_title>Find Your Parts</find_page_title>
                <empty_state_message>Pick a {make}, {model}, {year} or {part} to see matching products.</empty_state_message>
                <save_button_text>Save Selection</save_button_text>
                <garage_empty_prompt>Save a selection here for one-click reload later.</garage_empty_prompt>
            </copy>
            <oem>
                <enabled>0</enabled>
                <attribute_codes>sku</attribute_codes>
                <search_label>Or search by part number</search_label>
                <search_placeholder>Type part number…</search_placeholder>
            </oem>
        </etechflow_vehiclecompat>
    </default>
</config>
