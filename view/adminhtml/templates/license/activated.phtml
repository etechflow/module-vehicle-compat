<div class="etf-success">
    <div class="check err-icon">!</div>
    <h1>Activation Failed</h1>
    <p class="sub">The portal could not complete the license activation.</p>
    <div class="err-msg"><?= $block->escapeHtml($err) ?></div>
    <a href="<?= $managementUrl ?>" class="btn-ghost">&larr; Back to gate</a>
    <a href="<?= $settingsUrl ?>" class="btn-ghost">Configuration</a>
</div>
<?php else: ?>
<div class="etf-success">
    <div class="check">&#10003;</div>
    <h1>License Activated</h1>
    <p class="sub">Payment received. Vehicle Compatibility is now unlocked<?php if ($plan !== ''): ?> on the <strong><?= $plan ?></strong> plan<?php endif; ?>.</p>

    <div class="keybox" id="etf-key"><?= $licenseKey ?></div>
    <button class="copy" onclick="etfCopyKey(this)">Copy License Key</button>
    <a href="<?= $settingsUrl ?>" class="btn-ghost">Open Configuration</a>

    <div class="notes">
        <h3>What happens now</h3>
        <ol>
            <li>The key has been saved automatically to your store config.</li>
            <li>The module unlocks immediately on this domain.</li>
            <li>If the cache wasn&#39;t auto-flushed, run <code>bin/magento cache:flush</code>.</li>
            <li>Ongoing validation: the module re-checks the portal periodically. If your subscription is suspended remotely, the module locks shortly after.</li>
            <li>Change the key later: <a href="<?= $settingsUrl ?>">Configuration &rarr; License</a>.</li>
        </ol>
    </div>
</div>
