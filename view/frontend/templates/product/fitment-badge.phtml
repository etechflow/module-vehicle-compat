<?php
/**
 * "This fits: …" badge on the product detail page.
 *
 * @var \ETechFlow\VehicleCompat\Block\Product\FitmentBadge $block
 * @var \Magento\Framework\Escaper $escaper
 */
if (!$block->isVisible()) {
    return;
}

$data = $block->getRenderData();
$prefix   = (string) $data['prefix'];
$fitments = $data['fitments'];
$more     = (int) $data['more'];
$style    = (string) $data['style'];
?>
<div class="etechflow-vc-fitment etechflow-vc-fitment--<?= $escaper->escapeHtmlAttr($style) ?>" role="note">
    <span class="etechflow-vc-fitment__icon" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
        </svg>
    </span>
    <span class="etechflow-vc-fitment__text">
        <strong><?= $escaper->escapeHtml($prefix) ?></strong>
        <?php foreach ($fitments as $i => $fitment): ?>
            <span class="etechflow-vc-fitment__item"><?= $escaper->escapeHtml($fitment) ?></span><?php if ($i < count($fitments) - 1 || $more > 0): ?>, <?php endif; ?>
        <?php endforeach; ?>
        <?php if ($more > 0): ?>
            <span class="etechflow-vc-fitment__more"><?= $escaper->escapeHtml(__('and %1 more', $more)) ?></span>
        <?php endif; ?>
    </span>
</div>
<style>
    .etechflow-vc-fitment {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin: 8px 0 12px;
        padding: 6px 12px;
        font-size: 13px;
        line-height: 1.4;
        border-radius: 4px;
        border-left: 3px solid;
    }
    .etechflow-vc-fitment__icon {
        flex-shrink: 0;
        width: 14px;
        height: 14px;
        display: inline-flex;
    }
    .etechflow-vc-fitment__text { flex: 1; }
    .etechflow-vc-fitment__item { font-weight: 600; }
    .etechflow-vc-fitment__more { font-style: italic; color: inherit; opacity: 0.75; }

    .etechflow-vc-fitment--success { background: #e8f5e9; color: #1b5e20; border-color: #43a047; }
    .etechflow-vc-fitment--info    { background: #e3f2fd; color: #0d47a1; border-color: #1976d2; }
    .etechflow-vc-fitment--warning { background: #fff8e1; color: #6e4400; border-color: #ffa000; }
    .etechflow-vc-fitment--neutral { background: #f5f5f5; color: #424242; border-color: #757575; }
</style>
