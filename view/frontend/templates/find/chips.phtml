<?php
/** @var \Etechflow\VehicleCompat\Block\FindResults $block */
/** @var \Magento\Framework\Escaper $escaper */

$chips = $block->getFilterChips();
$hasAnyFilter = $block->hasAnyFilter();
?>
<div class="vc-find-summary" style="max-width:1280px;margin:0 auto;padding:8px 1rem 0;font-family:inherit">
    <?php if (!empty($chips)): ?>
        <div style="display:flex;flex-wrap:wrap;gap:8px;margin:0 0 8px">
            <?php foreach ($chips as $c): ?>
                <span style="display:inline-flex;align-items:center;gap:6px;padding:6px 12px;background:<?= $escaper->escapeHtmlAttr($c['color']) ?>;color:#fff;border-radius:20px;font-size:.78rem;font-weight:700">
                    <span style="opacity:.85;font-weight:500"><?= $escaper->escapeHtml($c['label']) ?>:</span>
                    <span><?= $escaper->escapeHtml($c['value']) ?></span>
                </span>
            <?php endforeach; ?>
        </div>
    <?php elseif (!$hasAnyFilter): ?>
        <div style="padding:40px 0;text-align:center;background:#f7f8fb;border-radius:14px;margin-bottom:16px">
            <p style="font-size:1rem;color:#374151;font-weight:700;margin:0 0 6px"><?= $escaper->escapeHtml($block->getEmptyStateMessage()) ?></p>
            <p style="font-size:.82rem;color:#6b7280;margin:0"><?= $escaper->escapeHtml($block->getUseFormPrompt()) ?></p>
        </div>
    <?php endif; ?>
</div>
