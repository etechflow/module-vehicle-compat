<?php
/**
 * Shared Find-Your-Parts form fragment.
 * Renders 4 searchable comboboxes (Make / Model / Year / Parts Required)
 * + the FIND PARTS button. Used in: header modal, home hero (desktop+mobile),
 * product-detail find-right-part sidebar. ONE source of truth — fix icons /
 * markup here, every form on the site updates together.
 *
 * The host template must:
 *   1. Wrap this fragment in an element carrying x-data="vehicleCompatPartFinder('<url>')"
 *   2. Load the vehicleCompatPartFinder() JS function (defined once in header.phtml)
 *
 * Optional block data:
 *   $block->getData('vc_size')  — 'sm' | 'md' (default 'md'); controls field height/font
 */

/** @var \Magento\Framework\View\Element\Template $block */
/** @var \Magento\Framework\Escaper $escaper */
$vcSize = (string) ($block->getData('vc_size') ?: 'md');
$sm = $vcSize === 'sm';
?>
