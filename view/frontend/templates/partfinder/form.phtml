    <span class="vc-ico-left">
        <svg width="<?= $sm ? 14 : 16 ?>" height="<?= $sm ? 14 : 16 ?>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
