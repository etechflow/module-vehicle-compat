    <?php /* v1.1.1: Save Selection button — only rendered when garage is enabled.
            Calls the localStorage save helper that's already defined in the garage
            widget. Hidden until the customer has picked at least a Make so the
            button can't save an empty selection. */ ?>
    <?php if ($block->isSavedGarageEnabled()): ?>
    <button type="button"
            class="vc-save-selection"
            x-show="selectedMake"
            @click="
                if (window.etechflowGarageSave) {
                    if (window.etechflowGarageSave('etechflow_vc_garage_v1_store_<?= (int) $block->getRequest()->getParam('___store') ?: 1 ?>', 3)) {
                        savedFeedback = true;
                        setTimeout(() => { savedFeedback = false; }, 1500);
                    }
                }
            "
            aria-label="<?= $escaper->escapeHtmlAttr(__('Save current selection to your garage for later')) ?>">
        <span x-show="!savedFeedback">
